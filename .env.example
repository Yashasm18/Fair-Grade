# Backend environment variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── Required ──────────────────────────────────────────────────────────────────

# Google Gemini API key — get yours at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Optional ──────────────────────────────────────────────────────────────────

# Path to Google Cloud Vision service account JSON (for enhanced OCR)
# If not set, the system falls back to Gemini Vision for OCR.
# GOOGLE_APPLICATION_CREDENTIALS=./vision-key.json
